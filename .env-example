# Google Cloud & GECX Agent Configuration
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us
GECX_APP_ID=your-gecx-app-id
GECX_DEPLOYMENT_ID=your-gecx-deployment-id

# Optional: Path to Google Cloud Service Account credentials JSON file for local authentication
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Optional: Port for the FastAPI server (defaults to 8080)
# PORT=8080
